# Copy to .env.prod and fill in values:
#   cp .env.prod.example .env.prod

# --- Database (used by docker-compose postgres service) ---
POSTGRES_USER=study
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=study_assistant

# --- HTTP ---
HTTP_PORT=80

# --- API (server reads these via env_file) ---
JWT_SECRET=change_me_at_least_32_characters_long_random_string
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# LLM — 阿里云百炼示例
OPENAI_API_KEY=sk-your-bailian-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ASR — 讯飞（可选，不配则口语识别不可用）
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

# Admin account (created/updated on first API start)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

SPEECH_PASS_THRESHOLD=70
TTS_VOICE=en-US-JennyNeural
