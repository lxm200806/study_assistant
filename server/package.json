{
  "name": "study-assistant-server",
  "version": "1.0.0",
  "description": "学习助手服务端",
  "main": "dist/app.js",
  "scripts": {
    "dev": "bash dev.sh",
    "db:migrate": "bash ../scripts/db-migrate.sh",
    "db:studio": "bash -c 'source ../scripts/node-env.sh && node ./node_modules/prisma/build/index.js studio'",
    "build": "bash -c 'source ../scripts/node-env.sh && node ./node_modules/typescript/bin/tsc'",
    "start": "bash -c 'source ../scripts/node-env.sh && node dist/app.js'",
    "prisma:init": "bash -c 'source ../scripts/node-env.sh && node ./node_modules/prisma/build/index.js init'",
    "prisma:migrate": "bash -c 'source ../scripts/node-env.sh && node ./node_modules/prisma/build/index.js migrate dev'",
    "build:vocabulary": "bash -c 'source ../scripts/node-env.sh && node ./node_modules/ts-node/dist/bin.js scripts/vocabulary-import/build-all.ts --api'",
    "build:vocabulary:fast": "bash -c 'source ../scripts/node-env.sh && node ./node_modules/ts-node/dist/bin.js scripts/vocabulary-import/build-all.ts'",
    "prisma:generate": "bash -c 'source ../scripts/node-env.sh && node ./node_modules/prisma/build/index.js generate'"
  },
  "keywords": [
    "learning",
    "vocabulary",
    "AI"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.11.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "nodemon": "^3.0.2",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
