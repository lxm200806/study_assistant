# PostgreSQL（配合项目根目录 docker-compose.yml）
DATABASE_URL="postgresql://study:study123@localhost:5432/study_assistant?schema=public"

JWT_SECRET="your_jwt_secret_key_here_must_be_at_least_32_characters_long"
JWT_ACCESS_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3004

# 阿里云百炼（OpenAI 兼容，Key 不要加引号和分号；保存后 nodemon 会自动重启后端）
# OPENAI_API_KEY=sk-你的百炼Key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# Whisper 语音转写（可与 OPENAI_API_KEY 共用）
# WHISPER_API_KEY=
# WHISPER_BASE_URL=https://api.openai.com/v1
# WHISPER_MODEL=whisper-1
# SPEECH_PASS_THRESHOLD=70

# DeepSeek 陪聊（国内推荐）
# DEEPSEEK_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 讯飞流式 ASR（国内语音对话推荐，配置后优先于 Whisper）
# XFYUN_APP_ID=
# XFYUN_API_KEY=
# XFYUN_API_SECRET=
