generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  passwordHash  String
  isAdmin       Boolean   @default(false)
  plan          String    @default("free")
  planExpiresAt DateTime?
  wxOpenId      String?   @unique
  hasOnboarded  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  vocabularyStats VocabularyStat[]
  trainingRecords TrainingRecord[]
  chatRecords     ChatRecord[]
  speechUsageLogs SpeechUsageLog[]
  bookStudyProgress BookStudyProgress[]
  dailyStudyLogs  DailyStudyLog[]
  bookUnlocks     UserBookUnlock[]
  orgMembers      OrgMember[]
}

model Book {
  id          String      @id @default(uuid())
  name        String      @unique
  code        String      @unique
  description String?
  level       String
  wordCount   Int         @default(0)
  isFree      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  
  vocabulary     BookVocabulary[]
  studyProgress  BookStudyProgress[]
  unlocks        UserBookUnlock[]
}

model BookVocabulary {
  id          String      @id @default(uuid())
  bookId      String
  wordId      String
  sortOrder   Int         @default(0) @map("sort_order")
  
  book        Book        @relation(fields: [bookId], references: [id])
  word        Vocabulary  @relation(fields: [wordId], references: [id])
  
  @@unique([bookId, wordId])
}

model Vocabulary {
  id              String          @id @default(uuid())
  word            String
  meaning         String
  phonetic        String?
  imageUrl        String?
  exampleSentence String?
  englishMeaning  String?
  contentType     String?
  topic           String?
  tags            String[]        @default([])
  createdAt       DateTime        @default(now())
  
  vocabularyStats VocabularyStat[]
  trainingRecords TrainingRecord[]
  bookVocabulary  BookVocabulary[]
}

model BookStudyProgress {
  id               String   @id @default(uuid())
  userId           String
  bookId           String
  cycleStartedAt   DateTime @default(now())
  practicedWordIds String[] @default([])

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model VocabularyStat {
  id            String    @id @default(uuid())
  userId        String
  wordId        String
  type          String
  practiceCount Int       @default(0)
  correctCount  Int       @default(0)
  lastPractice  DateTime?
  mastery       Int       @default(0)
  due           DateTime?
  stability     Float     @default(0)
  difficulty    Float     @default(0)
  reps          Int       @default(0)
  lapses        Int       @default(0)
  fsrsState     String    @default("New")
  lastReview    DateTime?
  retrievability Float    @default(0)
  recentLapse   Boolean   @default(false)

  user   User       @relation(fields: [userId], references: [id])
  word   Vocabulary @relation(fields: [wordId], references: [id])

  @@unique([userId, wordId, type])
  @@index([userId, type, due])
}

model TrainingRecord {
  id         String    @id @default(uuid())
  userId     String
  wordId     String
  type       String
  isCorrect  Boolean
  createdAt  DateTime  @default(now())
  
  user   User       @relation(fields: [userId], references: [id])
  word   Vocabulary @relation(fields: [wordId], references: [id])
}

model ChatRecord {
  id         String    @id @default(uuid())
  userId     String
  role       String
  content    String
  mode       String?
  createdAt  DateTime  @default(now())
  
  user   User       @relation(fields: [userId], references: [id])
}

model SpeechUsageLog {
  id        String   @id @default(uuid())
  userId    String
  kind      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model DailyStudyLog {
  id        String   @id @default(uuid())
  userId    String
  date      String
  wordCount Int      @default(0)
  streak    Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

model UserBookUnlock {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  members OrgMember[]
  classes OrgClass[]
}

model OrgMember {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  role      String   @default("student")
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id])
  user User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
}

model OrgClass {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  bookCode  String?
  dailyGoal Int      @default(20)
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])
}