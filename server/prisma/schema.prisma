generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  vocabularyStats VocabularyStat[]
  trainingRecords TrainingRecord[]
  chatRecords     ChatRecord[]
  bookStudyProgress BookStudyProgress[]
}

model Book {
  id          String      @id @default(uuid())
  name        String      @unique
  code        String      @unique
  description String?
  level       String
  wordCount   Int         @default(0)
  createdAt   DateTime    @default(now())
  
  vocabulary     BookVocabulary[]
  studyProgress  BookStudyProgress[]
}

model BookVocabulary {
  id          String      @id @default(uuid())
  bookId      String
  wordId      String
  sortOrder   Int         @default(0) @map("sort_order")
  
  book        Book        @relation(fields: [bookId], references: [id])
  word        Vocabulary  @relation(fields: [wordId], references: [id])
  
  @@unique([bookId, wordId])
}

model Vocabulary {
  id              String          @id @default(uuid())
  word            String
  meaning         String
  phonetic        String?
  imageUrl        String?
  exampleSentence String?
  englishMeaning  String?
  contentType     String?
  topic           String?
  tags            String[]        @default([])
  createdAt       DateTime        @default(now())
  
  vocabularyStats VocabularyStat[]
  trainingRecords TrainingRecord[]
  bookVocabulary  BookVocabulary[]
}

model BookStudyProgress {
  id               String   @id @default(uuid())
  userId           String
  bookId           String
  cycleStartedAt   DateTime @default(now())
  practicedWordIds String[] @default([])

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model VocabularyStat {
  id            String    @id @default(uuid())
  userId        String
  wordId        String
  type          String
  practiceCount Int       @default(0)
  correctCount  Int       @default(0)
  lastPractice  DateTime?
  mastery       Int       @default(0)
  
  user   User       @relation(fields: [userId], references: [id])
  word   Vocabulary @relation(fields: [wordId], references: [id])
  
  @@unique([userId, wordId, type])
}

model TrainingRecord {
  id         String    @id @default(uuid())
  userId     String
  wordId     String
  type       String
  isCorrect  Boolean
  createdAt  DateTime  @default(now())
  
  user   User       @relation(fields: [userId], references: [id])
  word   Vocabulary @relation(fields: [wordId], references: [id])
}

model ChatRecord {
  id         String    @id @default(uuid())
  userId     String
  role       String
  content    String
  createdAt  DateTime  @default(now())
  
  user   User       @relation(fields: [userId], references: [id])
}